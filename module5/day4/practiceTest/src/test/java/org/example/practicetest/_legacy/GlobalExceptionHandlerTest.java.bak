package org.example.practicetest;

import org.example.practicetest.exception.DuplicateEmailException;
import org.example.practicetest.exception.GlobalExceptionHandler;
import org.example.practicetest.exception.MerchantNotFoundException;
import org.example.practicetest.exception.OrderNotFoundException;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;
import org.springframework.test.web.servlet.setup.MockMvcBuilders;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;

class GlobalExceptionHandlerTest {

    private MockMvc mockMvc;

    @BeforeEach
    void setUp() {
        mockMvc = MockMvcBuilders.standaloneSetup(new ThrowingController())
                .setControllerAdvice(new GlobalExceptionHandler())
                .build();
    }

    @Test
    void shouldReturn404ForMerchantNotFound() throws Exception {
        mockMvc.perform(get("/test/merchant-not-found").accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isNotFound())
                .andExpect(jsonPath("$.status").value("404"));
    }

    @Test
    void shouldReturn404ForOrderNotFound() throws Exception {
        mockMvc.perform(get("/test/order-not-found").accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isNotFound())
                .andExpect(jsonPath("$.status").value("404"));
    }

    @Test
    void shouldReturn409ForDuplicateEmail() throws Exception {
        mockMvc.perform(get("/test/duplicate").accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isConflict())
                .andExpect(jsonPath("$.status").value("409"));
    }

    @RestController
    private static class ThrowingController {
        @GetMapping("/test/merchant-not-found")
        void merchant() {
            throw new MerchantNotFoundException("Merchant missing");
        }

        @GetMapping("/test/order-not-found")
        void order() {
            throw new OrderNotFoundException("Order missing");
        }

        @GetMapping("/test/duplicate")
        void duplicate() {
            throw new DuplicateEmailException("Duplicate email");
        }
    }
}


